{
  "name": "mcp-server_http",
  "version": "1.0.0",
  "description": "MCP Server HTTP (Streamable) example implementation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "server": "npm run build && node dist/index.js",
    "server_stateless": "npm run build && node dist/index.stateless.js",
    "server_stateful": "npm run build && node dist/index.stateful.js",
    "server_prompt": "npm run build && node dist/index.prompt-and-resource.js",
    "server_resource": "npm run build && node dist/index.prompt-and-resource.js",
    "sample-api": "npm run build && node dist/sample-web-api.js",
    "client": "npm run build && npx -y @modelcontextprotocol/inspector --transport http --url http://localhost:3000/mcp",
    "verify_stateful_counter": "npm run build && powershell -ExecutionPolicy Bypass -File ./tools/verify-stateful-counter.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.17",
    "typescript": "^6.0.3"
  }
}
